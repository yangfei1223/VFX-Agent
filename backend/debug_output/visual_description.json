{
  "effect_name": "windows95_pixel_wave",
  "shape": {
    "type": "custom_pixel_grid",
    "description": "主体是一个由四个彩色矩形组成的波浪形窗口，其左侧伴随着由多个小方块（像素）组成的动态流。",
    "sdf_primitives": [
      "rect",
      "grid",
      "wave_deformation"
    ],
    "parameters": {
      "radius": null,
      "corner_radius": 0,
      "blend": 0.0
    }
  },
  "color": {
    "palette": [
      "#217A7A",
      "#E7645B",
      "#98C963",
      "#63A9D0",
      "#F0E24E",
      "#000000"
    ],
    "gradient_type": "none",
    "gradient_direction": "none",
    "opacity_range": [
      1.0,
      1.0
    ],
    "has_noise": false,
    "noise_type": "none"
  },
  "animation": {
    "loop_duration_s": 4.8,
    "easing": "ease_in_out",
    "phases": [
      {
        "name": "window_deformation",
        "time_range": [
          0.0,
          1.0
        ],
        "description": "窗口主体在水平方向上进行轻微的波浪形形变和摆动，模拟旗帜飘动。"
      },
      {
        "name": "pixel_stream_movement",
        "time_range": [
          0.0,
          1.0
        ],
        "description": "左侧的像素流从左上角向右下角移动，并逐渐消散。"
      },
      {
        "name": "pixel_stream_fade_and_reappear",
        "time_range": [
          0.0,
          1.0
        ],
        "description": "像素在移动过程中逐渐消失，并在新的位置重新生成，形成连续的流动感，颜色按黑、红、蓝的顺序循环。"
      }
    ],
    "time_function": "sin(t) / fract(t)"
  },
  "interaction": {
    "responds_to_pointer": false,
    "interaction_type": "none",
    "description": "无"
  },
  "post_processing": {
    "blur": false,
    "blur_radius": 0,
    "bloom": false,
    "bloom_intensity": 0.0,
    "chromatic_aberration": false
  },
  "overall_description": "该视效重现了经典的 Windows 95 启动动画。一个由四色矩形组成的窗口标志在画面中央，其主体进行着轻微的波浪形形变。左侧伴随着由黑色、红色和蓝色小方块组成的像素流，这些像素以波浪状的动态效果从左上角向右下角移动、消散并重新生成，形成连续的流动感。"
}