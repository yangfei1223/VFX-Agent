# ============================================================
# VFX-Agent v2.0 (codex OD mode) 配置
# ============================================================

# 服务配置
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173

# Codex 调用配置
# codex exec 通过本地代理访问 OpenAI API
CODEX_PROXY=http://127.0.0.1:7890
# 单 pipeline 硬超时（秒）
CODEX_TIMEOUT=600
# 通过阈值
PASSING_SCORE=0.85

# 截图配置
SCREENSHOT_WIDTH=1280
SCREENSHOT_HEIGHT=720
RENDER_TIMEOUT_MS=2000

# Pipeline workdir 根目录（每个 pipeline 一个子目录）
WORKDIR_ROOT=/tmp/vfx_workdirs

# Kimi Code backend (China-domestic; no proxy needed)
# Binary path: default ~/.kimi-code/bin/kimi (official install). Override to
# `kimi` if installed via `npm i -g @moonshot-ai/kimi-code`.
# KIMI_BIN_PATH=/Users/yangfei/.kimi-code/bin/kimi
KIMI_PROXY=
KIMI_TIMEOUT=600

# 旧 v1.0 PROXY 字段保留作为兼容（被 browser_render 用）
PROXY=http://127.0.0.1:7890
